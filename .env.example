DATABASE_URL=postgres://user:pass@ep-something.aws.neon.tech/neondb?sslmode=require
GROQ_API_KEY=gsk_...
OPENAI_API_KEY=sk-...
# Your personal WhatsApp number (digits only, international, no +). Receives
# owner-only command permissions like .broadcast and .sudo.
OWNER_NUMBER=2348012345678
# The bot's dedicated WhatsApp number — the phone you'll enter the pairing
# code on. Only set this if it differs from OWNER_NUMBER.
# BOT_NUMBER=2348087654321
BOT_NAME=Theseus-Yarard
PREFIX=.
DAILY_TOKEN_CAP=50000
IMAGE_DAILY_CAP=5
MEMORY_WINDOW=20
MEMORY_COMPRESS_AT=30
LOG_LEVEL=info
PORT=8080
NODE_ENV=production
# Optional:
# BOT_PERSONA="You are..."
# REMOVEBG_API_KEY=
